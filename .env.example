# Đường dẫn giải tương đối với thư mục gốc dự án (nơi chạy lệnh), không phải
# thư mục prisma/. Đây là thay đổi của Prisma 7 so với các phiên bản trước.
DATABASE_URL="file:./prisma/dev.db"

# URL gốc của app — dùng để dựng redirect URI cho OAuth. Đổi khi deploy.
APP_URL="http://localhost:3000"

# Đăng nhập Google — tạo OAuth Client (loại Web) tại
# https://console.cloud.google.com/apis/credentials và thêm redirect URI:
#   http://localhost:3000/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Đăng nhập GitHub — tạo OAuth App tại https://github.com/settings/developers
# với Authorization callback URL:
#   http://localhost:3000/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
